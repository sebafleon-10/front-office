# Front Office — environment variables
#
# The AI season debrief (/api/coach) calls Claude. To enable the live AI,
# copy this file to .env.local and paste your key below. Without it, the
# debrief gracefully falls back to a deterministic sample memo.
#
#   cp .env.example .env.local
#
# Get a key at https://console.anthropic.com/ . Keep .env.local out of git.
#
# For a public deploy: use a DEDICATED key with a monthly spend limit set in the
# Anthropic Console, and add ANTHROPIC_API_KEY as an encrypted env var in your
# host (Vercel/Netlify/etc.) — never commit it.

ANTHROPIC_API_KEY=

# Public site origin, used for absolute Open Graph / social-share image URLs.
# Set this to your deployed domain (e.g. https://frontoffice.yoursite.com).
# Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL=
